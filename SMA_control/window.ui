         <!-- Temp PID panel -->
         <item>
          <widget class="QWidget" name="widget_pid" native="true">
           <layout class="QHBoxLayout" name="hl_pid">
            <property name="leftMargin"><number>0</number></property>
            <property name="rightMargin"><number>0</number></property>
            <item>
             <widget class="QLabel" name="lbl_target">
              <property name="text"><string>Target Temp:</string></property>
             </widget>
            </item>
            <item>
             <widget class="QDoubleSpinBox" name="spin_target">
              <property name="singleStep"><double>0.5</double></property>
              <property name="value"><double>25.0</double></property>
             </widget>
            </item>
           </layout>
          </widget>
         </item>

         <!-- Force control panel -->
         <item>
          <widget class="QWidget" name="widget_force" native="true">
           <layout class="QHBoxLayout" name="hl_force">
            <property name="leftMargin"><number>0</number></property>
