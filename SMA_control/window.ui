           <property name="minimumSize"><size><width>0</width><height>50</height></size></property>
           <property name="styleSheet">
            <string>background-color: red; color: white; font-weight: bold; border-radius: 5px;</string>
           </property>
           <property name="text"><string>STOP (Emergency)</string></property>
          </widget>
