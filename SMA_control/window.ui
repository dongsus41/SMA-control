            </item>
            <item>
             <widget class="QDoubleSpinBox" name="spin_target_force">
              <property name="maximum"><double>9999.0</double></property>
              <property name="singleStep"><double>10.0</double></property>
              <property name="value"><double>100.0</double></property>
             </widget>
            </item>
           </layout>
          </widget>
         </item>

         <item>
          <spacer name="verticalSpacer">
           <property name="orientation"><enum>Qt::Vertical</enum></property>
           <property name="sizeHint" stdset="0">
            <size><width>20</width><height>20</height></size>
